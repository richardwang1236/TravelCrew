# ── LLM Configuration ──
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_TIMEOUT=300.0
LLM_MAX_RETRIES=3

# ── External API Keys ──
# Google Maps API (Places, Distance Matrix, Geocoding, Weather, Static Maps)
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# SerpApi (Google AI Mode search for must-visit place discovery)
# Obtain from: https://serpapi.com/manage-api-key
SERPAPI_KEY=your-serpapi-key

# Serper.dev (Google Images search for POI cover images)
# Obtain from: https://serper.dev/
SERPER_API_KEY=your-serper-api-key

# OpenWeatherMap (optional, fallback weather source)
# Obtain from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key

# Wikimedia Enterprise (optional, Wikivoyage articles)
# Obtain from: https://enterprise.wikimedia.com/
WIKIMEDIA_ENTERPRISE_USERNAME=
WIKIMEDIA_ENTERPRISE_PASSWORD=

# ── API Call Parameters ──
API_TIMEOUT=10.0
API_MAX_RETRIES=2
PLACES_SEARCH_RADIUS=5000
PLACES_RESULT_LIMIT=30

# ── Business Logic ──
MAX_REPLAN_ATTEMPTS=3

# ── Web Server ──
API_HOST=0.0.0.0
API_PORT=8000
SESSION_TTL_SECONDS=3600
MAX_CONCURRENT_SESSIONS=10
